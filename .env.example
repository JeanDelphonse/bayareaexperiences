# Bay Area Experiences — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# Database (MySQL for production, SQLite for dev)
DEV_DATABASE_URL=sqlite:///bae_dev.db
DATABASE_URL=mysql://bayarea:B@y@re@65!@localhost/bayareaexperiences

# Flask-Mail (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@bayareaexperiences.com
ADMIN_EMAIL=valuemanager.management@gmail.com

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Twilio SMS (optional — Contact Us notifications)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=+1xxxxxxxxxx
TWILIO_TO_NUMBER=+14088312101
SMS_ENABLED=True

# Anthropic Claude — AI Chat Widget (required for Chat With Us)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAT_MAX_TOKENS=1024
CHAT_HISTORY_LIMIT=10
CHAT_ENABLED=True

# Admin pagination (allowed: 10, 20, 50 — default 20)
ADMIN_PAGE_SIZE=20

# First-party analytics / tracking
TRACKING_ENABLED=True
TRACKING_SESSION_TIMEOUT=1800
TRACKING_RETENTION_DAYS=90
GEOIP_PROVIDER=ip-api
