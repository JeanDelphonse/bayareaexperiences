# Bay Area Experiences — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

FLASK_ENV=development
SECRET_KEY=change-me-to-a-long-random-string

# Database (MySQL for production, SQLite for dev)
DEV_DATABASE_URL=sqlite:///bae_dev.db
DATABASE_URL=mysql://bayarea:B@y@re@65!@localhost/bayareaexperiences

# Flask-Mail (SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your@email.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@bayareaexperiences.com
ADMIN_EMAIL=admin@bayareaexperiences.com

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Google reCAPTCHA v3
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
